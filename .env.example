# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Groq, used only by the explanation layer. Server-side only: this key is read
# inside a route handler and must never carry a NEXT_PUBLIC_ prefix.
# With this unset the app still works and serves the static per-type
# explanations instead.
GROQ_API_KEY=gsk_your-key

# Optional. Any model on Groq's OpenAI-compatible endpoint that supports
# JSON mode. Defaults to llama-3.3-70b-versatile.
LLM_MODEL=llama-3.3-70b-versatile
